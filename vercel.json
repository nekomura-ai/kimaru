{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/booking", "destination": "/booking.html" },
    { "source": "/signup", "destination": "/signup.html" },
    { "source": "/pro", "destination": "/pro.html" },
    { "source": "/pro-apply", "destination": "/pro-apply.html" },
    { "source": "/square", "destination": "/square.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/cat-key-admin", "destination": "/cat-key-admin.html" },
    { "source": "/api/birthday-mails", "destination": "/api/book?job=birthday-mails" }
  ],
  "crons": [
    { "path": "/api/birthday-mails", "schedule": "0 0 * * *" }
  ]
}
