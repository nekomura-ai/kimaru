APP_BASE_URL=https://your-site.netlify.app

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret

SESSION_SECRET=replace-with-a-long-random-session-secret
TOKEN_ENCRYPTION_KEY=replace-with-a-long-random-token-secret

SQUARE_WEBHOOK_SHARED_SECRET=optional-shared-secret-for-square-webhook
# プレミアムプラン(¥2,200/月・無料お試しなし)の Square サブスク plan variation id。
# Webhook がこの id のサブスクを検出したら plan='premium' を付与（未一致は従来どおり 'pro'）。
SQUARE_PREMIUM_PLAN_ID=

# メール送信（任意）。優先順位: Gmail SMTP → Resend → 未設定ならスキップ。
# 当面は Gmail（アプリパスワード）で運用。有料顧客が増えたら独自ドメイン+Resend に移行。
# ローカル(.env)では未設定推奨（誤送信防止・自動スキップ）。本番(Netlify env)にのみ設定。
GMAIL_USER=apointokimaru@gmail.com
GMAIL_APP_PASSWORD=replace-with-16-char-gmail-app-password
# 独自ドメイン移行後に使う Resend（Gmail未設定時のフォールバック）
RESEND_API_KEY=
BIRTHDAY_EMAIL_FROM=
BOOKING_EMAIL_FROM=
REMINDER_EMAIL_FROM=
BIRTHDAY_EMAIL_REPLY_TO=apointokimaru@gmail.com
# 送信経路の分離（決定13）。未設定なら BOOKING_EMAIL_FROM にフォールバック（単一ドメイン運用と互換）。
# 取引メール（予約確認/リマインダー/通知）と営業メール（サンキュー/勧誘/宣伝）でサブドメインを分ける。
TRANSACTIONAL_EMAIL_FROM=
MARKETING_EMAIL_FROM=
# Resend 配信イベント(bounce/complaint)Webhook の共有シークレット（任意。設定時はヘッダ一致を要求）。
RESEND_WEBHOOK_SECRET=
# サンキュー＋登録案内メール(#181)のHTTPエンドポイント認証（任意。未設定なら CRON_SECRET、それも無ければ無認証）。
THANKYOU_CRON_SECRET=

# Zoom 自動発行(#23・任意)。Server-to-Server OAuth の3点が揃うと location_type=zoom で自動作成。未設定なら手動URL運用。
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# 議事録ツール等からの inbound webhook(#24・任意)。設定時のみ /api/meeting-notes-webhook が有効。
MEETING_NOTES_WEBHOOK_SECRET=

# AIアシスト（プレミアムプラン・決定20）。OPENAI_API_KEY 未設定時はサーバが 503 を返し、
# フロントはルールベース提案にフォールバックする（＝開発中は安全に無効化）。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# 1ユーザーあたり月間リクエスト上限（フェアユース・#190）。
AI_ASSIST_MONTHLY_LIMIT=300
